# Copy to .env and fill in. Never commit .env.
PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/yaad
JWT_ACCESS_SECRET=       # node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_REFRESH_SECRET=      # same command, different value
REDIS_URL=rediss://default:PASSWORD@HOST:PORT
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=yaad-media
GROQ_API_KEY=
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
CLIENT_ORIGINS=http://localhost:5173
